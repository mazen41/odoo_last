<odoo>
    <record id="project_task_view_form_inherit_project_doc_gen" model="ir.ui.view">
        <field name="name">project.task.form.inherit.project.doc.gen</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form_from_project"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Project Documents" name="project_documents">
                    <group>
                        <button name="action_load_project_documents" 
                                type="object" 
                                string="Load Required Documents" 
                                class="oe_highlight"
                                help="Load document templates based on project type"/>
                        <button name="action_generate_project_documents" 
                                type="object" 
                                string="Generate Documents PDF" 
                                class="oe_highlight"
                                help="Generate PDFs for marked documents"/>
                    </group>
                    <field name="document_link_ids" widget="one2many_list">
                        <tree editable="bottom">
                            <field name="document_template_id" 
                                   domain="[('is_project_document', '=', True), 
                                            '|', ('building_type', '=', parent.project_id.building_type), 
                                            ('building_type', '=', 'all')]"
                                   />
                            <field name="is_required" widget="toggle_button"/>
                            <field name="generated_sign_request_id" readonly="1"/>
                        </tree>
                        <form>
                            <group>
                                <field name="document_template_id"/>
                                <field name="is_required"/>
                                <field name="generated_sign_request_id" readonly="1"/>
                            </group>
                        </form>
                    </field>
                </page>
            </notebook>
        </field>
    </record>
</odoo>
