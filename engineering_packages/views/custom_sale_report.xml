<odoo>
    <!-- 1. INHERIT the existing report action to use our new template -->
    <record id="sale.action_report_saleorder" model="ir.actions.report">
        <field name="name">Quotation / Order (Engineering)</field>
        <field name="report_name">engineering_packages.report_saleorder_custom_document</field>
        <field name="report_file">engineering_packages.report_saleorder_custom_document</field>
    </record>

    <!-- 2. DEFINE the custom PDF template design -->
    <template id="report_saleorder_custom_document">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc">
                <div class="article o_report_layout_custom_engineering">
                    <div class="page">
                        
                        <!-- HEADER -->
                        <div class="custom-header-eng row">
                            <div class="col-8">
                                <h2 style="color: #36454F;">DYNAMIC DESIGN</h2>
                                <h3 style="color: #555;">DYNAMIC ENGINEERING CONSULTANTS</h3>
                            </div>
                            <div class="col-4 text-left">
                                <img src="/engineering_packages/static/src/img/logo.png" style="max-height: 80px;"/>
                            </div>
                        </div>

                        <!-- TITLE BAR -->
                        <div class="title-bar-eng">
                            استشاريون لتصميم وإشراف، معماري - إنشائي، مباني وإنشاءات، تصميم وإدارة مشاريع
                        </div>

                        <!-- DATE -->
                        <div class="row mb-5">
                            <div class="col-12 text-left">
                                <strong>التاريخ:</strong> <span t-field="doc.date_order" t-options='{"widget": "date"}'/>
                            </div>
                        </div>

                        <!-- MAIN TITLE -->
                        <div class="main-title-eng">
                            عرض سعر خدمات إستشارية
                        </div>

                        <!-- CUSTOMER INFO -->
                        <div class="customer-info-eng mb-4">
                            <p><strong>الموضوع:</strong> عرض سعر تصميم وترخيص وإشراف مبنى <span t-field="doc.building_type"/>
                            </p>
                            <p><strong>السادة:</strong> <span t-field="doc.partner_id.name"/></p>
                            <p>تحية طيبة وبعد،</p>
                        </div>

                        <!-- SERVICES LIST (From Package Features) -->
                        <div class="services-list-eng mb-4" t-if="doc.package_features_html">
                            <p>يسرنا بأن نقدم لكم عرض السعر الخاص بالخدمات التالية:</p>
                            <!-- This t-out will render the UL/LI list correctly -->
                            <div t-out="doc.package_features_html" style="font-size: 14px;"/>
                        </div>
                        
                        <!-- PRICE -->
                        <div class="price-eng mb-4">
                            <strong>قيمة الأتعاب:</strong>
                            <span t-field="doc.amount_total" t-options='{"widget": "monetary", "display_currency": doc.currency_id}'/>
                        </div>

                        <!-- NOTES -->
                        <div class="notes-eng mb-4">
                            <strong>ملاحظات:</strong>
                            <ul>
                                <li>عرض السعر شامل رسوم جهات الدولة.</li>
                            </ul>
                        </div>

                        <!-- PAYMENT TERMS -->
                        <div class="payment-terms-eng mb-5">
                            <strong>شروط الدفع:</strong>
                            <p t-field="doc.payment_term_id.name"/>
                        </div>

                        <!-- CLOSING -->
                        <div class="closing-eng">
                            <p>مع خالص التحية والتقدير،</p>
                            <p><strong>ديناميك ديزاين للاستشارات الهندسية</strong></p>
                        </div>
                        
                        <!-- FOOTER -->
                        <div class="custom-footer-eng row" style="position: absolute; bottom: 0; width: 100%;">
                           <div class="col-2 text-center">
                                <img src="/engineering_packages/static/src/img/logo.png" style="max-height: 50px;"/>
                           </div>
                           <div class="col-10 text-center">
                               <span>الكويت - قبلة - قطعة 11 - شارع الصالحية - بناية 18 مكتب (1) الدور الأول</span><br/>
                               <span>T: 22911228 - 55955599 | E-mail: info@dynamicd.com</span>
                           </div>
                        </div>
                        
                    </div>
                </div>
            </t>
        </t>
    </template>
</odoo>
