<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================= -->
    <!--  1. MAIN PROJECT FORM (TEAM & BUTTONS)         -->
    <!-- ============================================= -->
    <record id="edit_project_form_engineering" model="ir.ui.view">
        <field name="name">project.project.form.engineering</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_start_workflow" 
                        string="بدء سير العمل (Start Workflow)" 
                        type="object" 
                        class="btn-primary" 
                        invisible="workflow_started == True or id == False"
                        help="Creates the initial tasks for this project's workflow."/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sale_order_id" readonly="1"/>
                
                <field name="workflow_started" invisible="1"/>
                <field name="triggered_steps" invisible="1"/>
                
                <group string="فريق العمل (Project Team)">
                    <group>
                        <field name="architect_id"/>
                        <field name="structural_id"/>
                        <field name="electrical_id"/>
                        <field name="draftsman_id"/>
                    </group>
                    <group>
                        <field name="secretary_id"/>
                        <field name="accountant_id"/>
                        <field name="facade_draftsman_id"/>
                        <field name="muni_draftsman_id"/>
                    </group>
                </group>

                <group string="بيانات الموقع (Site Details)">
                    <group>
                        <field name="building_type"/>
                        <field name="service_type"/>
                        <field name="governorate_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="region_id" 
                               domain="[('governorate_id', '=', governorate_id)]" 
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="area"/>
                    </group>
                    <group>
                        <field name="plot_no"/>
                        <field name="block_no"/>
                        <field name="street_no"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>


    <!-- ====================================================== -->
    <!--  2. TASK FORM (BUTTONS AND DYNAMIC CHECKLIST TABS)     -->
    <!-- ====================================================== -->
    <record id="view_task_form2_engineering_extended" model="ir.ui.view">
        <field name="name">project.task.form.engineering.extended</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="%(engineering_project.action_report_initial_design_form)d" 
                        string="طباعة نموذج المشروع (Print PDF)" 
                        type="action" 
                        class="btn-primary"/>

                <button name="action_send_task_form_whatsapp" 
                        string="إرسال واتساب (WhatsApp)" 
                        type="object" 
                        class="btn-success" 
                        icon="fa-whatsapp"/>

                <button name="action_view_parent_project"
                        string="الذهاب للمشروع (Go to Project)" 
                        type="object" 
                        icon="fa-briefcase"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="نموذج مكونات المشروع" name="project_details_form">
                    
                    <field name="workflow_step" invisible="1"/>
                    
                    <group>
                        <group>
                            <field name="project_components_completed" widget="boolean_toggle"/>
                        </group>
                    </group>

                    <group string="تفاصيل ومكونات المشروع">
                        <field name="project_components_text" 
                               widget="text" 
                               nolabel="1" 
                               placeholder="اكتب مكونات وتفاصيل المشروع هنا بوضوح..." 
                               style="min-height: 250px; font-size: 15px;"/>
                    </group>

                </page>
            </xpath>

        </field>
    </record>


    <!-- ====================================================== -->
    <!--  3. TASK KANBAN (DISABLE UNASSIGNED TASKS)             -->
    <!-- ====================================================== -->
    <record id="view_task_kanban_engineering_disable" model="ir.ui.view">
        <field name="name">project.task.kanban.engineering.disable</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <!-- التأكد من استخدام اسم الحقل الصحيح الموجود في البايثون -->
            <xpath expr="//templates" position="before">
                <field name="is_current_user_assigned"/>
            </xpath>
            
            <xpath expr="//t[@t-name='kanban-box']/div" position="attributes">
                <attribute name="t-attf-style">#{record.is_current_user_assigned.raw_value ? '' : 'pointer-events: none; opacity: 0.6;'}</attribute>
            </xpath>
        </field>
    </record>

</odoo>
