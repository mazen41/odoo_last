<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================= -->
    <!--  1. MAIN PROJECT FORM (TEAM & BUTTONS)         -->
    <!-- ============================================= -->
    <record id="edit_project_form_engineering" model="ir.ui.view">
        <field name="name">project.project.form.engineering</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="action_start_workflow" 
                        string="بدء سير العمل (Start Workflow)" 
                        type="object" 
                        class="btn-primary" 
                        invisible="workflow_started == True or id == False"
                        help="Creates the initial tasks for this project's workflow."/>
            </xpath>

            <xpath expr="//field[@name='partner_id']" position="after">
                <field name="sale_order_id" readonly="1"/>
                
                <field name="workflow_started" invisible="1"/>
                <field name="triggered_steps" invisible="1"/>
                
                <group string="فريق العمل (Project Team)">
                    <group>
                        <field name="architect_id"/>
                        <field name="structural_id"/>
                        <field name="electrical_id"/>
                        <field name="draftsman_id"/>
                    </group>
                    <group>
                        <field name="secretary_id"/>
                        <field name="accountant_id"/>
                        <field name="facade_draftsman_id"/>
                        <field name="muni_draftsman_id"/>
                    </group>
                </group>

                <group string="بيانات الموقع (Site Details)">
                    <group>
                        <field name="building_type"/>
                        <field name="service_type"/>
                        <field name="governorate_id" options="{'no_create': True, 'no_open': True}"/>
                        <field name="region_id" 
                               domain="[('governorate_id', '=', governorate_id)]" 
                               options="{'no_create': True, 'no_open': True}"/>
                        <field name="area"/>
                    </group>
                    <group>
                        <field name="plot_no"/>
                        <field name="block_no"/>
                        <field name="street_no"/>
                    </group>
                </group>
            </xpath>
        </field>
    </record>

    <!-- ====================================================== -->
    <!--  2. TASK FORM (BUTTONS AND DETAILS TEXTAREA)           -->
    <!-- ====================================================== -->
    <record id="view_task_form2_engineering_extended" model="ir.ui.view">
        <field name="name">project.task.form.engineering.extended</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//header" position="inside">
                <button name="%(engineering_project.action_report_initial_design_form)d" 
                        string="طباعة نموذج المشروع (Print PDF)" type="action" class="btn-primary"/>
                <button name="action_send_task_form_whatsapp" 
                        string="إرسال واتساب (WhatsApp)" type="object" class="btn-success" icon="fa-whatsapp"/>
                <button name="action_view_parent_project"
                        string="الذهاب للمشروع (Go to Project)" type="object" icon="fa-briefcase"/>
            </xpath>

            <xpath expr="//notebook" position="inside">
                <page string="نموذج مكونات المشروع" name="project_details_form">
                    <field name="workflow_step" invisible="1"/>
                    <field name="is_assigned_to_me" invisible="1"/>
                    
                    <div class="mb-3 mt-2">
                        <span class="text-muted ms-3">
                            <i class="fa fa-info-circle"/> يرجى كتابة مكونات المشروع والتفاصيل الإضافية هنا، ثم تحديد خيار "تم الانتهاء".
                        </span>
                    </div>

                    <!-- TEXT AREA FIELD FOR PROJECT DETAILS -->
                    <group>
                        <field name="project_details_text" 
                               widget="text" 
                               placeholder="اكتب تفاصيل ومكونات المشروع هنا..." 
                               nolabel="1" 
                               colspan="2" 
                               style="min-height: 250px; font-size: 15px;"/>
                    </group>
                    
                    <!-- CHECKBOX -->
                    <group>
                        <field name="project_details_completed" widget="boolean_toggle"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ====================================================== -->
    <!--  3. KANBAN VIEW (DISABLE UNASSIGNED TASKS)             -->
    <!-- ====================================================== -->
    <record id="view_task_kanban_engineering_extended" model="ir.ui.view">
        <field name="name">project.task.kanban.engineering.extended</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            
            <xpath expr="//kanban" position="inside">
                <field name="is_assigned_to_me"/>
            </xpath>

            <!-- 
                هذا الكود السحري يجعل أي بطاقة لمهمة غير معينة للموظف الحالي 
                باهتة قليلاً وتمنعه من الضغط عليها أو سحبها!
            -->
            <xpath expr="//t[@t-name='kanban-box']/div" position="attributes">
                <attribute name="t-attf-style">#{record.is_assigned_to_me.raw_value ? '' : 'pointer-events: none; opacity: 0.55;'}</attribute>
            </xpath>
            
        </field>
    </record>
</odoo>
