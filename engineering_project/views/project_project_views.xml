<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
    =================================================
    1. Add "Commitments" Tab to the TASK Form View
    =================================================
    This is the original code you provided. It correctly
    adds the tab to the project.task model.
    -->
    <record id="project_task_view_form_inherit_commitments" model="ir.ui.view">
        <field name="name">project.task.form.inherit.commitments</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="Commitments (تعهدات)" name="engineering_commitments">
                    
                    <!-- Buttons -->
                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <!-- Table -->
                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('is_commitment', '=', True)]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <!-- 🔥 SIGN BUTTON -->
                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

    <!--
    ====================================================
    2. Add "Commitments" Tab to the main PROJECT Form View
    ====================================================
    This new record adds the same tab to the main
    project.project model.
    -->
    <record id="project_project_view_form_inherit_commitments" model="ir.ui.view">
        <field name="name">project.project.form.inherit.commitments</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="Commitments (تعهدات)" name="engineering_commitments">
                    
                    <!-- Buttons -->
                    <div class="mb-3">
                        <button name="action_load_commitments"
                                type="object"
                                string="Load Templates"
                                class="btn-primary"
                                icon="fa-download"/>

                        <button name="action_generate_commitments_pdf"
                                type="object"
                                string="Generate PDFs"
                                class="btn-success ms-2"
                                icon="fa-file-pdf-o"/>
                    </div>

                    <!-- Table -->
                    <field name="commitment_ids">
                        <tree editable="bottom">
                            <field name="sign_template_id"
                                   domain="[('is_commitment', '=', True)]"
                                   options="{'no_create': True}"/>

                            <field name="is_required" widget="boolean_toggle"/>

                            <field name="sign_request_id" readonly="1"/>

                            <!-- 🔥 SIGN BUTTON -->
                            <button name="action_sign_now"
                                    type="object"
                                    string="Sign Now"
                                    class="btn-primary"
                                    attrs="{'invisible': [('sign_request_id','=',False)]}"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>

</odoo>
