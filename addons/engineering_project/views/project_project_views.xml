<odoo>
    <data>

        <!-- ===================== -->
        <!-- Project Form -->
        <!-- ===================== -->
        <record id="edit_project_form_engineering" model="ir.ui.view">
            <field name="name">project.project.form.engineering</field>
            <field name="model">project.project</field>
            <field name="inherit_id" ref="project.edit_project"/>
            <field name="arch" type="xml">

                <!-- Send Contract button -->
                <xpath expr="//header" position="inside">
                    <button name="action_create_and_send_contract_from_project"
                            type="object"
                            string="Send Contract"
                            class="btn-secondary"
                            invisible="[('stage_id.name', '!=', 'التعاقد وجمع الوثائق')]"/>
                </xpath>

                <!-- Add documents tab -->
                <xpath expr="//notebook" position="inside">
                    <page string="Project Documents">
                        <field name="document_ids">
                            <tree>
                                <field name="name"/>
                                <field name="sent_date"/>
                                <field name="sent_by_id"/>
                                <field name="quotation_id"/>
                            </tree>
                            <form>
                                <group>
                                    <field name="name"/>
                                    <field name="quotation_id"/>
                                    <field name="project_id"/>
                                    <field name="customer_id"/>
                                    <field name="pdf_file" filename="pdf_filename"/>
                                    <field name="pdf_filename" invisible="1"/>
                                </group>
                                <group>
                                    <field name="sent_date" readonly="1"/>
                                    <field name="sent_by_id" readonly="1"/>
                                </group>
                            </form>
                        </field>
                    </page>
                </xpath>

                <!-- Link quotation -->
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="sale_order_id"/>
                </xpath>

            </field>
        </record>


     <record id="view_project_kanban_engineering" model="ir.ui.view">
          
        <!-- ===================== -->
        <!-- Task Form -->
        <!-- ===================== -->
        <record id="edit_task_form_engineering_send_contract" model="ir.ui.view">
            <field name="name">project.task.form.engineering.send.contract</field>
            <field name="model">project.task</field>
            <field name="inherit_id" ref="project.view_task_form2"/>
            <field name="arch" type="xml">

                <!-- Create header and add Send Contract button -->
                <xpath expr="//form" position="inside">
                    <header>
                        <button name="action_create_and_send_contract_from_task"
                                type="object"
                                string="Send Contract"
                                class="btn-primary"/>
                        
                        <button name="action_view_parent_project"
                                type="object"
                                string="Go to Project"
                                icon="fa-briefcase"
                                class="btn-info"
                                invisible="[('project_id', '=', False)]"/>
                    </header>
                </xpath>

            </field>
        </record>

    </data>
</odoo>
