<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ==================================================================== -->
    <!--   Project Task View (Inheritance to add Pledge Tab)                  -->
    <!-- ==================================================================== -->
    <record id="edit_task_form_inherit_pledges" model="ir.ui.view">
        <field name="name">project.task.form.inherit.pledges</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            
            <xpath expr="//field[@name='project_id']" position="after">
                <field name="stage_sequence" invisible="1"/>
            </xpath>
            
            <xpath expr="//notebook" position="inside">
                <!-- New Tab for Municipality Pledges (Sign PDFs) -->
                <page string="تعهدات البلدية (Pledges PDFs)" name="municipality_pledges" invisible="stage_sequence != 2">
                    
                    <div class="mb-3">
                        <!-- Button to load relevant Sign Templates -->
                        <button name="action_load_required_pledges" 
                                string="تحميل التعهدات (Load PDF Templates)" 
                                type="object" 
                                class="btn-secondary" icon="fa-download"/>
                                
                        <!-- Button to generate Sign Requests (Documents) -->
                        <button name="action_generate_pledges_pdf" 
                                string="إنشاء المستندات (Generate Documents)" 
                                type="object" 
                                class="btn-primary ms-2" icon="fa-file-pdf-o"
                                invisible="not pledge_ids"/>
                    </div>
                    
                    <!-- List of Pledges linked to the task -->
                    <field name="pledge_ids">
                        <tree editable="bottom" decoration-success="is_completed==True">
                            <!-- Link to the Sign Template -->
                            <field name="sign_template_id" options="{'no_create': True}"/>
                            <!-- Checkbox to mark as required -->
                            <field name="is_completed" widget="boolean_toggle"/>
                            <!-- Link to the generated Sign Request document -->
                            <field name="sign_request_id" widget="many2one_button"/>
                        </tree>
                    </field>
                </page>
            </xpath>
        </field>
    </record>

    <!-- ==================================================================== -->
    <!--   Sign Template View (Inheritance to add custom fields)              -->
    <!-- ==================================================================== -->
    <record id="sign_template_view_form_inherit_pledge" model="ir.ui.view">
        <field name="name">sign.template.form.inherit.pledge</field>
        <field name="model">sign.template</field>
        <field name="inherit_id" ref="sign.sign_template_view_form"/>
        <field name="arch" type="xml">
            <!-- Add our custom fields after 'authorized_ids' -->
            <xpath expr="//field[@name='authorized_ids']" position="after">
                <field name="is_municipality_pledge" widget="boolean_toggle"/>
                <!-- Show building_type only if it's marked as municipality pledge -->
                <field name="building_type" invisible="is_municipality_pledge == False"/>
            </xpath>
        </field>
    </record>

    <!-- ==================================================================== -->
    <!--   Menus for Sign Templates                                           -->
    <!-- ==================================================================== -->

    <!-- Menu Item: List Municipality Pledge Sign Templates -->
    <!-- This menu will show only templates marked as 'is_municipality_pledge=True' -->
    <record id="action_project_sign_templates" model="ir.actions.act_window">
        <field name="name">قوالب تعهدات البلدية (PDFs)</field>
        <field name="res_model">sign.template</field>
        <field name="view_mode">kanban,tree,form</field>
        <!-- Domain filters to show only municipality pledges -->
        <field name="domain">[('is_municipality_pledge', '=', True)]</field>
        <!-- Context sets the default value when creating a NEW template from this action -->
        <field name="context" eval="{'default_is_municipality_pledge': True}"/>
    </record>

    <menuitem id="menu_project_pledge_sign_templates"
              name="قوالب تعهدات البلدية (PDF)"
              parent="project.menu_project_config"
              action="action_project_sign_templates"
              sequence="50"/>
              
    <!-- NEW Menu Item: Action to create a new Sign Template -->
    <!-- This will open the Sign app's creation wizard -->
    <record id="action_sign_template_creation" model="ir.actions.act_window">
        <field name="name">إنشاء قالب تعهد جديد</field>
        <field name="res_model">sign.template</field>
        <field name="view_mode">form</field> <!-- Force form view for creation -->
        <field name="target">new</field> <!-- Open in a wizard/modal -->
        <!-- Context automatically sets 'is_municipality_pledge' to True when creating -->
        <field name="context" eval="{'default_is_municipality_pledge': True}"/>
    </record>

    <!-- NEW Menu Item: Link to create a new template directly -->
    <!-- This menu will be placed under the main Sign app's Templates menu -->
    <menuitem id="menu_create_new_sign_template"
              name="إنشاء قالب جديد"
              parent="sign.menu_sign_templates" <!-- Parent is the main Templates menu in the Sign app -->
              action="action_sign_template_creation"
              sequence="10"/>
</odoo>
