<odoo>
    <record id="edit_project_form_inherit_pledges" model="ir.ui.view">
        <field name="name">project.project.form.inherit.pledges</field>
        <field name="model">project.project</field>
        <field name="inherit_id" ref="project.edit_project"/>
        <field name="arch" type="xml">
            
            <xpath expr="//notebook" position="inside">
                <page string="تعهدات البلدية (Municipality Pledges)" name="municipality_pledges">
                    
                    <button name="action_load_required_pledges" 
                            string="تحميل التعهدات المطلوبة (Load Required Pledges)" 
                            type="object" 
                            class="btn-secondary mb-3" icon="fa-download"/>
                    
                    <field name="pledge_ids">
                        <tree editable="bottom" decoration-success="is_completed==True" decoration-danger="is_completed==False">
                            <field name="template_id" options="{'no_create': True}"/>
                            <field name="is_completed" widget="boolean_toggle"/>
                        </tree>
                    </field>

                </page>
            </xpath>

        </field>
    </record>
</odoo>
